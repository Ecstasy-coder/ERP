<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Events / Meetings Calendar</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/static/styles.css" rel="stylesheet">
</head>
<body>

<div class="container mt-4">
  <div class="text-center mb-4">
    <h1 class="page-title">Events/Meetings</h1>
    <h4 id="monthTitle"></h4>
  </div>

  <div class="calendar-controls mb-4 p-3 rounded shadow-sm">
    <div class="row">
      <div class="col-md-8">
        <label class="form-label mb-1">Branch</label>
        <select id="branchFilter" class="form-select branch-select">
          <option value="">All Branches</option>
          <% branches.forEach(branch => { %>
            <option value="<%= branch.name %>"><%= branch.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4 text-md-end">
        <a href="/meetings/new" class="btn btn-brown btn-sm">Add New</a>
      </div>
    </div>
    <div class="row mt-3">
      <div class="col-md-8">
        <div class="d-flex flex-wrap align-items-center gap-2">
          <button id="prevMonth" class="btn btn-warning btn-sm">&lt; Previous</button>
          <button id="currentMonth" class="btn btn-success btn-sm">Current Month</button>
          <button id="nextMonth" class="btn btn-warning btn-sm">Next &gt;</button>
        </div>
      </div>
    </div>

    <div class="text-center mt-3">
      <h4 id="monthTitle" class="month-title mb-0"></h4>
    </div>
  </div>

  <div class="calendar-card">
    <div class="table-responsive">
      <table class="table calendar-table mb-0">
        <thead>
          <tr>
            <th>Sunday</th>
            <th>Monday</th>
            <th>Tuesday</th>
            <th>Wednesday</th>
            <th>Thursday</th>
            <th>Friday</th>
            <th>Saturday</th>
          </tr>
        </thead>
        <tbody id="calendarBody"></tbody>
      </table>
    </div>
  </div>
</div>

<script src="/static/calendar.js"></script>
</body>
</html>


