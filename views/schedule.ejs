<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Schedule Meeting</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/static/styles.css" rel="stylesheet">
</head>
<body>
<div class="container mt-4">
  <div class="meeting-form-card mx-auto mt-3" style="max-width: 1000px;">
    <div class="row align-items-center mb-4">
      <div class="col-12 text-center">
        <h1 class="page-title mb-0">Meeting Schedule</h1>
      </div>
      <div class="col-12 text-md-end mt-3">
        <a href="/meetings/calendar" class="btn btn-dark">Close</a>
        <button type="submit" form="meetingForm" class="btn btn-outline-secondary">Save</button>
      </div>
    </div>

    <form id="meetingForm" class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Branch</label>
        <select id="branch" name="branch" class="form-select">
          <% branches.forEach(branch => { %>
            <option value="<%= branch.name %>"><%= branch.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-6">
        <label class="form-label">Title</label>
        <input id="title" name="title" type="text" class="form-control" placeholder="Meeting title" required />
      </div>

      <div class="col-12">
        <label class="form-label">Description</label>
        <textarea id="description" name="description" class="form-control" rows="4" placeholder="Meeting description"></textarea>
      </div>

      <div class="col-md-6">
        <label class="form-label">Start Date</label>
        <input id="startDate" name="start_datetime" type="datetime-local" class="form-control" required />
      </div>
      <div class="col-md-6">
        <label class="form-label">End Date</label>
        <input id="endDate" name="end_datetime" type="datetime-local" class="form-control" required />
      </div>

      <div class="col-12 required-section">
        <h5 class="mb-3">Required People</h5>
        <div class="row gy-3">
          <div class="col-lg-4">
            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="required_people_type" value="everyone" id="everyoneRadio" checked />
              <label class="form-check-label" for="everyoneRadio">Everyone</label>
            </div>
            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="required_people_type" value="specific" id="specificRadio" />
              <label class="form-check-label" for="specificRadio">Specific People</label>
            </div>
            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="required_people_type" value="class_students" id="classStudentsRadio" />
              <label class="form-check-label" for="classStudentsRadio">Class Students</label>
            </div>
          </div>
          <div class="col-lg-8">
            <div class="panel-box hidden" id="specificPeopleOptions">
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="allEmployee" value="All Employee" />
                <label class="form-check-label" for="allEmployee">All Employee</label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="allTeachers" value="All Teachers" />
                <label class="form-check-label" for="allTeachers">All Teachers</label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="allStudents" value="All Students" />
                <label class="form-check-label" for="allStudents">All Students</label>
              </div>
            </div>
            <div class="panel-box hidden" id="classSectionRow">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Class</label>
                  <select id="classSelect" name="class" class="form-select">
                    <% classes.forEach(item => { %>
                      <option value="<%= item %>"><%= item %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Section</label>
                  <select id="sectionSelect" name="section" class="form-select">
                    <% sections.forEach(item => { %>
                      <option value="<%= item %>"><%= item %></option>
                    <% }) %>
                  </select>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12">
        <div id="messageBox" class="alert alert-danger d-none"></div>
      </div>
    </form>
  </div>
</div>
<script src="/static/schedule.js"></script>
</body>
</html>
